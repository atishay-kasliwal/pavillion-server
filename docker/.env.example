# Copy this file to `.env` in the same directory and fill in real values.
# `.env` is gitignored — never commit real secrets.

# --- Shared ---
TZ=America/Los_Angeles

# This machine's Tailscale IP (`tailscale ip -4`). Used to bind services
# that should be reachable from your own devices over the tailnet directly
# (native mobile apps, etc.) without exposing them on the LAN or internet.
TAILSCALE_IP=100.64.0.1

# NVMe SSD, for random-I/O-heavy pieces: Postgres data + ML model cache.
FAST_LOCATION=/mnt/fast

# --- Immich ---
# Where photo/video originals live on the host disk. HDD, bulk capacity.
UPLOAD_LOCATION=/mnt/data/immich
IMMICH_DB_PASSWORD=change-me-immich-db-password
IMMICH_VERSION=release

# --- Navidrome ---
# Path to your existing music library (read-only mount).
MUSIC_LOCATION=/mnt/data/music
NAVIDROME_DB_LOCATION=/mnt/data/navidrome
ND_LOGLEVEL=info

# --- Filebrowser ---
# Root of the general-purpose archive (everything not photos/music).
FILEBROWSER_ROOT=/mnt/data/files
FILEBROWSER_DB_LOCATION=/mnt/data/filebrowser

# --- Custom API ---
API_PORT=8090
IMMICH_API_KEY=change-me-generate-in-immich-admin-ui
IMMICH_BASE_URL=http://immich-server:2283
NAVIDROME_BASE_URL=http://navidrome:4533
NAVIDROME_USERNAME=change-me
NAVIDROME_PASSWORD=change-me
FILEBROWSER_BASE_URL=http://filebrowser:80
FILEBROWSER_USERNAME=change-me
FILEBROWSER_PASSWORD=change-me
# Header Cloudflare Access injects with the verified identity, forwarded by
# the API for basic access logging (not used for authorization — Access
# already gates the tunnel before traffic reaches this box).
CF_ACCESS_IDENTITY_HEADER=Cf-Access-Authenticated-User-Email
# Comma-separated origin(s) the frontend is served from (Cloudflare Pages
# domain, e.g. https://pavillion.pages.dev). Leave blank until the frontend
# is deployed — the API reflects any origin in that case — then set it to
# lock CORS down to just that origin.
FRONTEND_ORIGIN=

# App-level login (see api/src/routes/auth.js) — a second layer behind
# Cloudflare Access, not a replacement for it. Generate the hash with:
#   docker compose run --rm archive-api node scripts/hash-password.js <password>
APP_LOGIN_USERNAME=change-me
APP_LOGIN_PASSWORD_HASH=change-me
SESSION_SECRET=change-me-random-string

# Direct large-upload bypass (see README "Uploading files over 100 MB").
# Files over 100 MB can't go through Cloudflare (100 MB body cap → 413), so
# they upload directly to the box over the tailnet (Tailscale HTTPS). That
# cross-domain request can't carry the session cookie, so the /api/upload
# route accepts this key instead. Set the SAME value as the frontend's
# VITE_DIRECT_UPLOAD_KEY. Blank disables the bypass (>100 MB files then fail
# with a clear "connect to Tailscale" message). Any random string works — it
# isn't a secret; the tailnet-only reachability of the direct origin is the
# real gate.
UPLOAD_DIRECT_KEY=
