# Standalone-run reference only. Inside Docker Compose, all of this comes
# from docker/.env via `env_file:` — you don't need this file there.

PORT=8090
MUSIC_DIR=/music

IMMICH_BASE_URL=http://localhost:2283
IMMICH_API_KEY=change-me

NAVIDROME_BASE_URL=http://localhost:4533
NAVIDROME_USERNAME=change-me
NAVIDROME_PASSWORD=change-me

FILEBROWSER_BASE_URL=http://localhost:8091
FILEBROWSER_USERNAME=change-me
FILEBROWSER_PASSWORD=change-me

CF_ACCESS_IDENTITY_HEADER=Cf-Access-Authenticated-User-Email

# Comma-separated origin(s) the frontend is served from. Blank reflects
# any origin (fine before a frontend exists) — lock it down once deployed.
FRONTEND_ORIGIN=

# App-level login (see routes/auth.js) — a second layer behind Cloudflare
# Access. Generate the hash with: node scripts/hash-password.js <password>
APP_LOGIN_USERNAME=change-me
APP_LOGIN_PASSWORD_HASH=change-me
SESSION_SECRET=change-me-random-string
